{
  "name": "oauth-blueprint",
  "description": "OAuth-protected document storage blueprint",
  "version": "0.2.0-alpha.1",
  "master_revision": "Latest",
  "manager": {
    "Evm": "OauthBlueprintBSM"
  },
  "jobs": [
    {
      "name": "write_doc",
      "job_index": 0,
      "inputs": [
        "string",
        "string",
        "string"
      ],
      "outputs": [
        "tuple(bool,string,string)"
      ],
      "required_results": 1,
      "description": "Persist a document for a tenant"
    },
    {
      "name": "admin_purge",
      "job_index": 1,
      "inputs": [
        "string"
      ],
      "outputs": [
        "tuple(bool,string)"
      ],
      "required_results": 1,
      "description": "Purge all documents for a tenant"
    }
  ]
}