# Tangle Cloud Operator Harness — Environment Variables
#
# Copy this file: cp .env.harness.example .env.harness
# Fill in the values, then: source .env.harness
#
# Only fill in the keys for blueprints you want to run.
# Use --only to start a subset: cargo tangle harness up --only llm-operator,vector-operator

# ── LLM Backend ──────────────────────────────────────────────────────────
# URL of an OpenAI-compatible API (vLLM, OpenRouter, Together, Groq).
# The LLM blueprint proxies all chat/completion requests here.
VLLM_BACKEND_URL=https://openrouter.ai/api/v1
# HuggingFace token for gated models (Llama, Mistral, etc.)
HF_TOKEN=

# ── Embedding Backend ────────────────────────────────────────────────────
# URL of a text-embedding API (TEI, OpenAI, etc.)
EMBEDDING_BACKEND_URL=https://api.openai.com/v1

# ── Image / Video (Replicate) ────────────────────────────────────────────
REPLICATE_API_TOKEN=

# ── Voice (OpenAI Whisper / TTS) ─────────────────────────────────────────
OPENAI_API_KEY=

# ── Avatar (HeyGen) ─────────────────────────────────────────────────────
HEYGEN_API_KEY=

# ── Router Registration ─────────────────────────────────────────────────
# If using production router, operators need a public URL.
# Start a tunnel: ngrok http 9001
# Then set: PUBLIC_BASE_URL=https://abc123.ngrok-free.app
# Each blueprint's public_url in the TOML can reference this.
PUBLIC_BASE_URL=http://localhost
